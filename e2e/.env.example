#===============================================================================
# Playwright 测试环境变量配置
#===============================================================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 根据实际环境修改配置值
# 3. 运行测试前执行：source e2e/.env
#
# 或者直接在运行测试时设置：
#   export BASE_URL=http://localhost:8080
#   npx playwright test
#===============================================================================

#-------------------------------------------------------------------------------
# 前端 URL 配置
#-------------------------------------------------------------------------------
# 优先级：BASE_URL > FRONTEND_URL > 默认值 (http://localhost:8080)

# 基础 URL (推荐)
BASE_URL=http://localhost:8080

# 前端 URL (可选，与 BASE_URL 相同)
# FRONTEND_URL=http://localhost:8080

#-------------------------------------------------------------------------------
# 后端 API URL (用于 API 测试)
#-------------------------------------------------------------------------------
API_URL=http://localhost:8080/api

#-------------------------------------------------------------------------------
# 测试环境配置
#-------------------------------------------------------------------------------
# 是否在 CI 环境中运行 (true/false)
CI=false

# 浏览器配置
# BROWSER=chromium
# HEADLESS=true

#-------------------------------------------------------------------------------
# 测试账号配置 (用于需要登录的测试)
#-------------------------------------------------------------------------------
# 注意：敏感信息不应提交到版本控制系统
TEST_ADMIN_USERNAME=admin
TEST_ADMIN_PASSWORD=Admin@2026

#-------------------------------------------------------------------------------
# 使用示例
#-------------------------------------------------------------------------------
# 本地测试：
#   source e2e/.env
#   npx playwright test
#
# 指定 URL 测试：
#   export BASE_URL=http://192.168.1.100:8080
#   npx playwright test
#
# CI 环境测试：
#   export CI=true
#   export BASE_URL=http://ci-server:8080
#   npx playwright test
#===============================================================================
