#===============================================================================
# 摄像头生命周期管理系统 - 环境变量配置模板
#===============================================================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 修改下面的配置值
# 3. 确保 .env 文件不被提交到 git（已在 .gitignore 中配置）
#
# 生成随机密钥方法：
#   - Linux/Mac: openssl rand -base64 32
#   - 在线生成：https://generate-secret.vercel.app/32
#===============================================================================

#-------------------------------------------------------------------------------
# 服务器配置
#-------------------------------------------------------------------------------
SERVER_IP=127.0.0.1
DOMAIN=localhost

#-------------------------------------------------------------------------------
# 数据库配置 (PostgreSQL)
#-------------------------------------------------------------------------------
# 数据库连接信息
DB_HOST=localhost
DB_PORT=5432
DB_NAME=camera_construction_db
DB_USERNAME=postgres
# ⚠️ 必须修改：使用强密码（至少 12 位，包含大小写字母、数字、特殊字符）
DB_PASSWORD=YourSecurePassword123!

# 数据库连接池配置（可选）
DB_POOL_MAX=50
DB_POOL_MIN=10

#-------------------------------------------------------------------------------
# Redis 配置
#-------------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
# ⚠️ 建议设置：生产环境必须设置 Redis 密码
REDIS_PASSWORD=

#-------------------------------------------------------------------------------
# JWT 认证配置
#-------------------------------------------------------------------------------
# ⚠️ 必须修改：使用强随机字符串（至少 32 位）
# 生成命令：openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=86400000

#-------------------------------------------------------------------------------
# 文件存储配置
#-------------------------------------------------------------------------------
# 存储类型：local, minio, oss
FILE_STORAGE_TYPE=local

# 本地存储配置（当 FILE_STORAGE_TYPE=local 时）
FILE_UPLOAD_DIR=/var/www/uploads

# MinIO 配置（当 FILE_STORAGE_TYPE=minio 时）
MINIO_ENDPOINT=http://localhost:9000
# ⚠️ 必须修改：生产环境不要使用默认值
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=camera-system

# 阿里云 OSS 配置（当 FILE_STORAGE_TYPE=oss 时）
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_ACCESS_KEY=your-oss-access-key
OSS_SECRET_KEY=your-oss-secret-key
OSS_BUCKET=your-oss-bucket

#-------------------------------------------------------------------------------
# 后端服务配置
#-------------------------------------------------------------------------------
BACKEND_PORT=8080
# 日志文件路径
LOG_FILE=/var/log/camera-system/application.log

#-------------------------------------------------------------------------------
# Nginx 配置
#-------------------------------------------------------------------------------
NGINX_WWW_DIR=/var/www/html
NGINX_LOG_DIR=/var/log/nginx

#-------------------------------------------------------------------------------
# SSL/HTTPS 配置（可选）
#-------------------------------------------------------------------------------
SSL_EMAIL=admin@example.com
SSL_CERT_PATH=/etc/letsencrypt/live/your-domain.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/your-domain.com/privkey.pem

#-------------------------------------------------------------------------------
# 短信验证码配置（可选）
#-------------------------------------------------------------------------------
SMS_ENABLED=false
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY=
SMS_ACCESS_SECRET=
SMS_SIGN_NAME=

#-------------------------------------------------------------------------------
# 邮件配置（可选）
#-------------------------------------------------------------------------------
MAIL_ENABLED=false
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
